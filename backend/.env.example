# Database — replace user, password, host, and dbname with your actual values
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# App
APP_PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-secret
# JWT expiry string (e.g., 1d, 8h, 7d) — used for jwt.sign expiresIn
JWT_EXPIRY=1d
# Cookie max-age in milliseconds (must be <= JWT_EXPIRY in ms for consistency)
# Default: 86400000 (24 hours)
JWT_COOKIE_MAX_AGE=86400000

# CORS — comma-separated list of allowed origins (for standalone frontend dev)
# If using Vite proxy (default), this isn't needed since requests are same-origin.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# FRONTEND_URL — URL of the frontend app, used in email templates to link to issues
FRONTEND_URL=http://localhost:5173

# SMTP — required for email notifications (assignment alerts, overdue warnings)
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=you@gmail.com
#
# Mailtrap (free sandbox for dev/testing — https://mailtrap.io):
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=<mailtrap-username>
# SMTP_PASS=<mailtrap-password>
# SMTP_FROM=noreply@issuetracker.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
